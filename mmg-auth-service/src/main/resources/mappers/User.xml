<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.green.mmg.auth.user.UserMapper">

    <!-- 회원가입 -->
    <insert id="signup" useGeneratedKeys="true" keyProperty="userNo">
        INSERT INTO user (user_id, user_pw, name, gender, birth, tel, role)
        VALUES (#{userId}, #{userPw}, #{name}, #{gender}, #{birth}, #{tel}, #{role})
    </insert>

    <!-- 로그인용 유저 조회 -->
    <select id="findByUserId" resultType="com.green.mmg.auth.user.model.User">
        SELECT user_no
             , user_id
             , user_pw
             , role
             , name
             , birth
             , gender
             , green
             , kind
             , rank
             , tel
        FROM user
        WHERE user_id = #{userId}
    </select>

    <!-- 아이디 중복확인 -->
    <select id="countByUserId" resultType="int">
        SELECT COUNT(*)
        FROM user
        WHERE user_id = #{userId}
    </select>

    <!-- 내 정보 조회 -->
    <select id="findByUserNo" resultType="com.green.mmg.auth.user.model.User">
        SELECT user_id
             , name
             , tel
             , gender
             , birth
        FROM user
        WHERE user_no = #{userNo}
    </select>

    <!-- 내 정보 수정 -->
    <update id="update">
        UPDATE user
        SET user_no = user_no
        <if test="name != null and name != ''">
            , name = #{name}
        </if>
        <if test="tel != null and tel != ''">
            , tel = #{tel}
        </if>
        <if test="gender != 0">
            , gender = #{gender}
        </if>
        <if test="birth != null and birth != ''">
            , birth = #{birth}
        </if>
        <if test="userPw != null and userPw != ''">
            , user_pw = #{userPw}
        </if>
        WHERE user_no = #{userNo}
    </update>

    <!-- 리뷰 SQL은 Phase 2에서 main-service의 UserMapper 또는 ReviewMapper에 신규 작성 -->

    <!-- ============== Internal API (Phase 4-A) ============== -->

    <!-- /internal/auth/user/{userNo} 단건 -->
    <select id="findBriefByUserNo" resultType="com.green.mmg.common.dto.feign.UserBriefDto">
        SELECT user_no    AS userNo,
               name       AS name,
               tel        AS tel,
               ''         AS address
        FROM user
        WHERE user_no = #{userNo}
    </select>

    <!-- /internal/auth/users?ids=... batch -->
    <select id="findBriefsByUserNos" resultType="com.green.mmg.common.dto.feign.UserBriefDto">
        SELECT user_no    AS userNo,
               name       AS name,
               tel        AS tel,
               ''         AS address
        FROM user
        WHERE user_no IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

</mapper>
