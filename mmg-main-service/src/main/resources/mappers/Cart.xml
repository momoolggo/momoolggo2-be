<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.green.mmg.main.cart.CartMapper">

    <!--
      Phase 3-B-3 하이브리드 잔존 (3 SQL):
      - findStoreIdByMenuId: menu → menu_category JOIN
      - findStoreNameByStoreId: Store 도메인 경계 위반 (Phase 3-D에서 정리)
      - findCartItems: cart_detail → menu JOIN + 응답 DTO 직접 매핑

      11개 단순 CRUD + getLastCartId 1개는 CartRepository / CartDetailRepository로 이전.
      getLastCartId 제거 사유: JPA save() 후 entity.cartId 자동 채움으로 완전 대체, 회귀 위험 0
      (decisions.md 보존 정책 예외 등재).
    -->

    <select id="findStoreIdByMenuId" resultType="Long">
        SELECT mc.store_id
        FROM menu m
                 JOIN menu_category mc ON m.category_id = mc.category_id
        WHERE m.menu_id = #{menuId}
    </select>

    <select id="findStoreNameByStoreId" resultType="String">
        SELECT store_name
        FROM store
        WHERE store_id = #{storeId}
    </select>

    <select id="findCartItems" resultType="com.green.mmg.main.cart.model.CartItemRes">
        SELECT
            cd.cart_item_id AS id,
            cd.menu_id      AS menuId,
            m.name          AS menuName,
            m.price         AS price,
            cd.quantity     AS quantity,
            m.menu_pic      AS menuPic
        FROM cart_detail cd
                 JOIN menu m ON cd.menu_id = m.menu_id
        WHERE cd.cart_id = #{cartId}
    </select>

    <!-- 외부 호출 (Order/Payment) — Phase 3-C 정리 시 제거 예정 -->
    <select id="findCartEntityByUserNo" resultType="com.green.mmg.main.cart.model.Cart">
        SELECT cart_id AS cartId, user_no AS userNo, store_id AS storeId
        FROM cart
        WHERE user_no = #{userNo}
        LIMIT 1
    </select>

    <delete id="deleteAllCartItems">
        DELETE FROM cart_detail
        WHERE cart_id = #{cartId}
    </delete>

    <delete id="deleteCart">
        DELETE FROM cart
        WHERE cart_id = #{cartId}
    </delete>

</mapper>
